":true},"thumb_avatar_url":{"urls":["https:\u002F\u002Fp11.douyinpic.com\u002Faweme\u002F100x100\u002Faweme-avatar\u002Ftos-cn-i-0813_o4EWA6fBCE7reK0ArmjlD4zcDCRA4iyAiAAIIg.jpeg?from=3782654143","https:\u002F\u002Fp3.douyinpic.com\u002Faweme\u002F100x100\u002Faweme-avatar\u002Ftos-cn-i-0813_o4EWA6fBCE7reK0ArmjlD4zcDCRA4iyAiAAIIg.jpeg?from=3782654143","https:\u002F\u002Fp26.douyinpic.com\u002Faweme\u002F100x100\u002Faweme-avatar\u002Ftos-cn-i-0813_o4EWA6fBCE7reK0ArmjlD4zcDCRA4iyAiAAIIg.jpeg?from=3782654143"],"need_complete_url":true},"secret":false,"test_tag":0,"vip_stage":"svip","is_vip":true,"public_name":"嘿嘿唔呼","is_luna_user":true}},"service_id":"luna","ip_label":"湖南"},{"id":"7614592044086182691","content":"巴西funk没有复杂的歌词，只有魔性又慵懒的节奏，却能瞬间把人拉进一种松弛又上头的氛围里。简单的旋律循环往复，像夜晚里不用思考的放空，像走路时自带的气场BGM。\n《MONTAGEM 486》真正厉害的地方，是用最简单的元素，做出了最抓人的气场。\n魔性的哼唱、慵懒又带劲的鼓点，没有多余的修饰，却自带一种让人忍不住跟着点头的魔力。\n \n它不刻意煽情，也不强行炸场，只是安静地释放节奏，却能让人瞬间进入状态。\n不管是走路、开车、熬夜、放松，这首歌都能稳稳托住你的情绪，低调、上头、越听越上瘾。\n听过很多洗脑神曲，但能一直留在列表里反复循环的，486绝对算一个。","count_digged":221,"time_created":1772946482,"user":{"id":"2214893447813770","nickname":"沈皖晴oR","medium_avatar_url":{"urls":["https:\u002F\u002Fp3.douyinpic.com\u002Faweme\u002F720x720\u002Faweme-avatar\u002Ftos-cn-i-0813c000-ce_o0FEiVD9FA8vrsaeA9QOACWAy68IQnAfwpVqgE.jpeg?from=3782654143","https:\u002F\u002Fp26.douyinpic.com\u002Faweme\u002F720x720\u002Faweme-avatar\u002Ftos-cn-i-0813c000-ce_o0FEiVD9FA8vrsaeA9QOACWAy68IQnAfwpVqgE.jpeg?from=3782654143","https:\u002F\u002Fp11.douyinpic.com\u002Faweme\u002F720x720\u002Faweme-avatar\u002Ftos-cn-i-0813c000-ce_o0FEiVD9FA8vrsaeA9QOACWAy68IQnAfwpVqgE.jpeg?from=3782654143"],"need_complete_url":true},"thumb_avatar_url":{"urls":["https:\u002F\u002Fp3.douyinpic.com\u002Faweme\u002F100x100\u002Faweme-avatar\u002Ftos-cn-i-0813c000-ce_o0FEiVD9FA8vrsaeA9QOACWAy68IQnAfwpVqgE.jpeg?from=3782654143","https:\u002F\u002Fp11.douyinpic.com\u002Faweme\u002F100x100\u002Faweme-avatar\u002Ftos-cn-i-0813c000-ce_o0FEiVD9FA8vrsaeA9QOACWAy68IQnAfwpVqgE.jpeg?from